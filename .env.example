NODE_ENV=development
PORT=3000

# From the host with docker-compose postgres (port 5434 -> container 5432):
DATABASE_URL=postgresql://postgres:password@localhost:5434/agurkha_db

POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=agurkha_db

JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

CORS_ORIGIN=*

# Used once to bootstrap the first SUPER_ADMIN via POST /api/v1/auth/setup
SETUP_SECRET=change-this-to-a-strong-secret
